# Supabase
# Project URL (Settings > Data API ou Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Use a "Publishable key" (sb_publishable_...) no Supabase hospedado,
# ou a "anon key" (JWT) se estiver usando chaves legadas/self-host.
EXPO_PUBLIC_SUPABASE_ANON_KEY=cole-sua-chave-aqui

# Opcional: Google Maps
# Observação: só declarar aqui não configura o native; exige configuração no app.json/app.config
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=sua-chave-aqui

# Observação:
# - Se você deixar as variáveis EXPO_PUBLIC_SUPABASE_URL e EXPO_PUBLIC_SUPABASE_ANON_KEY vazias,
#   o app entra em modo OFFLINE e usa o SQLite (offline.db) como banco de referência.
